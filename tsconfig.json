{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/providers/**/*.ts",
    "components/providers/**/*.tsx",
    "components/stage/**/*.ts",
    "components/stage/**/*.tsx",
    "components/chrome/**/*.ts",
    "components/chrome/**/*.tsx",
    "components/scenes/**/*.ts",
    "components/scenes/**/*.tsx",
    "components/footer/**/*.ts",
    "components/footer/**/*.tsx",
    "components/booking/**/*.ts",
    "components/booking/**/*.tsx",
    "components/ui/**/*.ts",
    "components/ui/**/*.tsx",
    "lib/scroll-store.ts",
    "lib/booking-store.ts",
    "lib/booking/**/*.ts",
    "lib/supabase/**/*.ts",
    "lib/notifications/**/*.ts",
    "lib/utils.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
