# pnpm needs to lift the React-Three-Fiber / React-Spring family up to the
# flat node_modules path so Next.js's webpack resolver can find them while
# walking transitive imports (e.g. @react-three/drei -> @react-spring/three).
# Without these hoists pnpm leaves the packages only under .pnpm/* and the
# bundler throws ENOENT on chunk build.
public-hoist-pattern[]=*@react-spring*
public-hoist-pattern[]=*@react-three*
public-hoist-pattern[]=three
public-hoist-pattern[]=@types/three
auto-install-peers=true
