# =============================================================================
# All variables below are OPTIONAL. The marketing site, booking (WhatsApp),
# and admin snapshot scraper work with zero API keys.
# =============================================================================

# --- Admin (/admin, /admin/scraper) — set a strong password in production ---
# ADMIN_PASSWORD=change-me
# Optional: separate HMAC secret for signed session cookies (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=

# --- Supabase (optional — slot booking + admin booking list) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: AI-shaped scraper rows (otherwise Cheerio snapshot only) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Optional: contact form email (otherwise submissions succeed without send) ---
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=
# EMAIL_FROM=

# --- Optional: Twilio WhatsApp alerts ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# RECEPTIONIST_PHONE=

# --- Optional: public URL for sitemap/robots ---
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- Optional: Google Maps / Places (unused if not referenced in UI) ---
# NEXT_PUBLIC_GOOGLE_API_KEY=
